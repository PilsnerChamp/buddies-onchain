{
  "name": "buddy-onchain",
  "description": "An AI buddy in your terminal — one per account, non-transferable, living fully onchain on Base. No host. No takedown. Go hatch yours.",
  "version": "1.2.1",
  "license": "MIT",
  "author": {
    "name": "PilsnerChamp",
    "url": "https://buddies-onchain.xyz"
  },
  "homepage": "https://buddies-onchain.xyz",
  "repository": "https://github.com/PilsnerChamp/buddies-onchain",
  "keywords": ["buddy", "buddies", "companion", "onchain", "base", "nft", "identity"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "-c",
              "command -v node >/dev/null 2>&1 && exec node \"$0\" \"$@\"; printf '%s\\n' 'buddy-onchain plugin is installed but dormant: Node.js (>=18) is not on PATH, so the buddy cannot appear. If the user asks about the buddy or runs /buddy-onchain, tell them to install Node.js and start a new session.'",
              "${CLAUDE_PLUGIN_ROOT}/dist/index.js",
              "--session-start"
            ],
            "timeout": 5,
            "statusMessage": "Resolving buddy on-chain..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "-c",
              "command -v node >/dev/null 2>&1 && exec node \"$0\" \"$@\"; printf '{}'",
              "${CLAUDE_PLUGIN_ROOT}/dist/index.js",
              "--hook"
            ],
            "timeout": 10,
            "statusMessage": "Tracking buddy mode..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh",
            "args": [
              "-c",
              "command -v node >/dev/null 2>&1 && exec node \"$0\" \"$@\"; exit 0",
              "${CLAUDE_PLUGIN_ROOT}/dist/index.js",
              "--stop"
            ],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
