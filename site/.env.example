# Active chain at build time. Values: local | sepolia | mainnet (default: local).
VITE_CHAIN=local

# WalletConnect project ID for the RainbowKit connector. Get one at
# https://reown.com. Unset → wagmi falls back to a `dev` sentinel
# so dev builds don't crash; the WalletConnect modal will not pair without a
# real project ID.
# VITE_WALLETCONNECT_PROJECT_ID=
