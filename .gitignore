# Dependencies
node_modules/

# Build output
.output/
dist/
# Marketplace install ships only `plugin/` subtree; dist/index.js must be tracked
# so the bundled artifact (with ~shared/* inlined) runs without a build step.
!plugin/dist/
!plugin/dist/index.js

# Foundry
out/
cache/
onchain/lib/
onchain/broadcast/

# Deployment manifests: commit canonical chains only.
#   31337 (local anvil) — deterministic, tracked.
#   8453  (Base mainnet) — canonical runtime pointer, committed on deploy day.
# Base Sepolia (84532) is throwaway validation — redeploy on demand, never commit.
# sync-deployments still copies it into plugin/ for local runs; both copies stay ignored.
onchain/deployments/84532.json
plugin/deployments/84532.json

# Environment variables
# .env = non-secrets (committed)
# .env.local = secrets (ignored)
.env.local
.env.*.local
.env.worktree

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
logs/

# Temp
.tmp/

# Worktrees (parallel development directories)
trees/
_examples/
**/__pycache__/
.claude/data/

# Renderer / E2E tool output
onchain/tools/output/

# Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/settings.local.json
